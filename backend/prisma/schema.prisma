generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  isActive  Boolean  @default(true)
  role      UserRole @default(CASHIER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Division {
  id           Int       @id @default(autoincrement())
  divisionName String
  divisionCode String    @unique
  sector       Sector?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  cashiers     Cashier[]
  ddos         DDO[]
}

model DDO {
  id          Int       @id @default(autoincrement())
  ddoName     String
  ddoEmail    String?
  ddoPhone    String?
  ddoPassword String?
  isActive    Boolean   @default(true)
  divisionId  Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  ddoCode     String    @unique
  cashiers    Cashier[]
  division    Division  @relation(fields: [divisionId], references: [id])
}

model Cashier {
  id          Int      @id @default(autoincrement())
  name        String
  email       String?
  phone       String?
  password    String?
  isActive    Boolean  @default(true)
  divisionId  Int
  ddoId       Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  cashierCode String   @unique
  
  ddo         DDO      @relation(fields: [ddoId], references: [id])
  division    Division @relation(fields: [divisionId], references: [id])
}

model ExpenditureType {
  id        Int      @id @default(autoincrement())
  name      String
  sector    Sector?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PlanNonPlan {
  id        Int      @id @default(autoincrement())
  name      String
  sector    Sector?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ObjectHead {
  id        Int      @id @default(autoincrement())
  name      String
  sector    Sector?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Department {
  id        Int      @id @default(autoincrement())
  name      String
  code      String
  sector    Sector?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserRole {
  ADMIN
  CASHIER
}

enum Sector {
  COUNCIL
  STATE
}
