generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             Int              @id @default(autoincrement())
  name           String
  email          String           @unique
  password       String
  isActive       Boolean          @default(true)
  role           UserRole         @default(CASHIER)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  cashReceipt    CashReceipt[]
  challans       Challan[]
  expenditures   Expenditure[]
  openingBalance OpeningBalance[]
  treasuryPla    TreasuryPla[]
  stateChallan   StateChallan[]
}

model Division {
  id           Int       @id @default(autoincrement())
  divisionName String
  divisionCode String    @unique
  sector       Sector?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  cashiers     Cashier[]
  challans     Challan[]
  ddos         DDO[]
}

model DDO {
  id           Int           @id @default(autoincrement())
  ddoName      String
  ddoEmail     String?
  ddoPhone     String?
  ddoPassword  String?
  isActive     Boolean       @default(true)
  divisionId   Int
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  ddoCode      String        @unique
  cashiers     Cashier[]
  challans     Challan[]
  division     Division      @relation(fields: [divisionId], references: [id])
  expenditures Expenditure[]
}

model Cashier {
  id          Int      @id @default(autoincrement())
  name        String
  email       String?
  phone       String?
  password    String?
  isActive    Boolean  @default(true)
  divisionId  Int
  ddoId       Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  cashierCode String   @unique
  ddo         DDO      @relation(fields: [ddoId], references: [id])
  division    Division @relation(fields: [divisionId], references: [id])
}

model ExpenditureType {
  id        Int      @id @default(autoincrement())
  name      String
  sector    Sector?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PlanNonPlan {
  id        Int      @id @default(autoincrement())
  name      String
  sector    Sector?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ObjectHead {
  id        Int      @id @default(autoincrement())
  name      String
  sector    Sector?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Department {
  id           Int           @id @default(autoincrement())
  name         String
  code         String        @unique
  sector       Sector?
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  challans     Challan[]
  expenditures Expenditure[]
}

model Grants {
  id        Int      @id @default(autoincrement())
  name      String
  code      String
  sector    Sector?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Heads {
  id                Int      @id @default(autoincrement())
  sector            Sector
  grantName         String
  grantNo           String
  majorHead         String
  majorHeadCode     String
  subMajor          String?
  subMajorCode      String?
  minorHead         String?
  minorHeadCode     String?
  subHead           String?
  subHeadCode       String?
  subSubHead        String?
  subSubHeadCode    String?
  detailHead        String?
  detailHeadCode    String?
  subDetailHead     String?
  subDetailHeadCode String?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model ChallanHeads {
  id                   Int      @id @default(autoincrement())
  majorHead            String
  subMajor             String?   // Sub Major Head name
  minorHead            String?   // Minor Head name
  subHead              String?   // Sub Head name
  subSubHead           String?   // Sub Sub Head name
  detailHead           String?   // Detail Head name  ← NEW
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @default(now()) @updatedAt
  majorHeadCode        String   @default("0")
  subMajorCode         String?  @default("0")
  subMajorParentCode   String?  @default("0")   // parent: majorHeadCode

  // Level 3 — Minor Head  (was subSubMajor)
  minorHeadCode        String?  @default("0")
  minorHeadParentCode  String?  @default("0")   // parent: subMajorCode

  // Level 4 — Sub Head  (was minorHead)
  subHeadCode          String?  @default("0")
  subHeadParentCode    String?  @default("0")   // parent: minorHeadCode

  // Level 5 — Sub Sub Head  (was detailHead)
  subSubHeadCode       String?  @default("0")
  subSubHeadParentCode String?  @default("0")   // parent: subHeadCode

  // Level 6 — Detail Head  ← NEW
  detailHeadCode       String?  @default("0")
  detailHeadParentCode String?  @default("0")   // parent: subSubHeadCode
}


model Challan {
  id                  Int         @id @default(autoincrement())
  cashierId           Int
  counterfoilNo       String?
  counterfoilDate     DateTime?
  challanNo           String?
  challanDate         DateTime?
  challanType         ChallanType
  departmentId        Int
  divisionId          Int
  ddoId               Int
  majorHead           String
  subMajorHead        String
  subSubMajorHead     String
  minorHead           String
  detailHead          String
  treasuryCode        String?
  treasuryChallanNo   String?
  treasuryChallanDate DateTime?
  amount              String
  remarks             String
  isActive            Boolean     @default(true)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  user                User        @relation(fields: [cashierId], references: [id])
  ddo                 DDO         @relation(fields: [ddoId], references: [id])
  department          Department  @relation(fields: [departmentId], references: [id])
  division            Division    @relation(fields: [divisionId], references: [id])
}

model CashReceipt {
  id            Int       @id @default(autoincrement())
  cashierId     Int
  counterfoilNo String?
  date          DateTime?
  receivedFrom  String?
  letterNo      String?
  letterDate    DateTime?
  rupeesInCash  String?
  byChequeBank  String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sector        Sector    @default(COUNCIL)
  user          User      @relation(fields: [cashierId], references: [id])
}

model Expenditure {
  id                        Int               @id @default(autoincrement())
  /// ================= BASIC DETAILS =================
  sector                    Sector
  voucherNo                 String
  voucherDate               DateTime?
  requisitionNo             String?
  requisitionDate           DateTime?
  grantNo                   String?
  departmentId              Int
  ddoId                     Int
  workName                  String?
  expenditureType           String
  /// ================= HEAD OF ACCOUNT =================
  majorHead                 String
  subMajorHead              String?
  minorHead                 String?
  subHead                   String?
  subSubHead                String?
  detailHead                String?
  subDetailHead             String?
  /// ================= CLASSIFICATION =================
  salaryType                SalaryType
  financialYear             String
  objectHead                String?
  /// ================= AMOUNT BREAKUP =================
  payOfficers               Decimal?          @db.Decimal(14, 2)
  payEstablishment          Decimal?          @db.Decimal(14, 2)
  allowanceHonorary         Decimal?          @db.Decimal(14, 2)
  contingencies             Decimal?          @db.Decimal(14, 2)
  grantsInAid               Decimal?          @db.Decimal(14, 2)
  works                     Decimal?          @db.Decimal(14, 2)
  loansAdvances             Decimal?          @db.Decimal(14, 2)
  loanType                  LoanType?
  loanRepayGovt             Decimal?          @db.Decimal(14, 2)
  loanRepayOther            Decimal?          @db.Decimal(14, 2)
  securityDeposit           Decimal?          @db.Decimal(14, 2)
  earnestMoney              Decimal?          @db.Decimal(14, 2)
  transferPayment           Decimal?          @db.Decimal(14, 2)
  /// ================= TOTAL =================
  grossAmount               Decimal           @db.Decimal(14, 2)
  /// ================= DEDUCTIONS =================
  cgst                      Decimal?          @db.Decimal(14, 2)
  sgst                      Decimal?          @db.Decimal(14, 2)
  igst                      Decimal?          @db.Decimal(14, 2)
  earnestMoneyDeduction     Decimal?          @db.Decimal(14, 2)
  ptax                      Decimal?          @db.Decimal(14, 2)
  itax                      Decimal?          @db.Decimal(14, 2)
  carLoanRecovery           Decimal?          @db.Decimal(14, 2)
  houseLoanRecovery         Decimal?          @db.Decimal(14, 2)
  cpfCouncil                Decimal?          @db.Decimal(14, 2)
  cpfContribution           Decimal?          @db.Decimal(14, 2)
  cpfRecovery               Decimal?          @db.Decimal(14, 2)
  houseRent                 Decimal?          @db.Decimal(14, 2)
  securityDepositsDeduction Decimal?          @db.Decimal(14, 2)
  forestRoyalty             Decimal?          @db.Decimal(14, 2)
  monopoly                  Decimal?          @db.Decimal(14, 2)
  mcForestRoyalty           Decimal?          @db.Decimal(14, 2)
  mdrrf                     Decimal?          @db.Decimal(14, 2)
  dmft                      Decimal?          @db.Decimal(14, 2)
  labourCess                Decimal?          @db.Decimal(14, 2)
  itForestRoyalty           Decimal?          @db.Decimal(14, 2)
  vat                       Decimal?          @db.Decimal(14, 2)
  advanceRecovery           Decimal?          @db.Decimal(14, 2)
  otherDeductions           Decimal?          @db.Decimal(14, 2)
  grossDeduction            Decimal           @db.Decimal(14, 2)
  cpfPayable                Decimal           @db.Decimal(14, 2)
  netDeduction              Decimal           @db.Decimal(14, 2)
  netAmount                 Decimal           @db.Decimal(14, 2)
  amountPayable             Decimal           @db.Decimal(14, 2)
  amountInWords             String
  /// ================= REMARKS =================
  remarks                   String?
  /// ================= CHEQUE & TREASURY =================
  chequeBookNo              String?
  chequeNo                  String?
  chequeIssueDate           DateTime?
  treasuryName              String?
  treasuryVoucherNo         String?
  treasuryDate              DateTime?
  /// ================= STATUS =================
  isActive                  Boolean           @default(true)
  createdAt                 DateTime          @default(now())
  updatedAt                 DateTime          @updatedAt
  planType                  String
  cashierId                 Int
  user                      User              @relation(fields: [cashierId], references: [id])
  ddo                       DDO               @relation(fields: [ddoId], references: [id])
  department                Department        @relation(fields: [departmentId], references: [id])
  challansfrombill          challanFromBill[]
}

model OpeningBalance {
  id        Int      @id @default(autoincrement())
  cashierId Int
  amount    Decimal  @db.Decimal(14, 2)
  month     Int
  year      Int
  sector    Sector?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [cashierId], references: [id])
}

model TreasuryPla {
  id        Int      @id @default(autoincrement())
  cashierId Int
  amount    Decimal  @db.Decimal(14, 2)
  month     Int
  year      Int
  sector    Sector?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [cashierId], references: [id])
}

model challanTwo {
  id                              Int      @id @default(autoincrement())
  kaacChallanNo                   String
  kaacChallanDate                 DateTime
  sector                          Sector?
  majorHead                       String?
  subMajor                        String?
  minorHead                       String?
  divisonCode                     String?
  ddoCode                         String?
  treasuryCode                    String?
  treasuryChallanNo               String?
  treasuryChallanDate             DateTime
  loansReceivedGovt               Decimal? @db.Decimal(14, 2)
  loansReceivedOther              Decimal? @db.Decimal(14, 2)
  depositReceivedTransferredItems Decimal? @db.Decimal(14, 2)
  grantsInAid                     Decimal? @db.Decimal(14, 2)
  amount                          Decimal? @db.Decimal(14, 2)
  narration                       String?
  isActive                        Boolean  @default(true)
  createdAt                       DateTime @default(now())
  updatedAt                       DateTime @updatedAt
}

model challanFromBill {
  id                  Int         @id @default(autoincrement())
  challanNo           String
  idFromExpenditure   Int
  sector              Sector?
  departmentId        Int?
  ddoId               Int?
  majorHead           String?
  subMajor            String?
  minorHead           String?
  treasuryCode        String?
  voucharDate         DateTime
  amount              Decimal?    @db.Decimal(14, 2)
  amountType          String
  chequeNo            String?
  chequeDate          DateTime
  salaryNonSalary     String?
  expenditureType     String?
  treasuryChallanNo   String?
  treasuryChallanDate DateTime
  isActive            Boolean     @default(true)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  expenditure         Expenditure @relation(fields: [idFromExpenditure], references: [id], onDelete: Cascade)
}

model cashbookInformations {
  id                      Int      @id @default(autoincrement())
  sector                  Sector?
  month                   Int?
  year                    Int?
  financialYear           String?
  receiptCashColumn       Decimal? @db.Decimal(14, 2)
  receiptTreasuryPla      Decimal? @db.Decimal(14, 2)
  disbursementCashColumn  Decimal? @db.Decimal(14, 2)
  disbursementTreasuryPla Decimal? @db.Decimal(14, 2)
  isActive                Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model StateChallan {
  challanNo          String?
  challanDate        DateTime?
  cashierId          Int
  stateNo            String?
  from               String?
  to                 String?
  subject            String?
  ddo                String?
  divisionCode       String?
  majorHead          String?
  subMajorHead       String?
  minorHead          String?
  subHead            String?
  subSubHead         String?
  detailHead         String?
  subDetailHead      String?
  purpose            String?
  remarks            String?
  totalAmount        Float?
  amountInWords      String?
  focNo              String?
  sanctionLetterNo   String?
  sanctionLetterDate DateTime?
  treasuryCode       String?
  treasuryChallanNo  String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  sector             Sector
  id                 Int       @id @default(autoincrement())
  user               User      @relation(fields: [cashierId], references: [id])

  @@map("state_challans")
}

enum SalaryType {
  SALARY
  NON_SALARY
}

enum PlanType {
  PLAN
  NON_PLAN
}

enum LoanType {
  BUILDING_LOAN
  CAR_LOAN
}

enum UserRole {
  ADMIN
  CASHIER
}

enum Sector {
  COUNCIL
  STATE
}

enum ChallanType {
  STATE
  COUNCIL
  CSS
}




