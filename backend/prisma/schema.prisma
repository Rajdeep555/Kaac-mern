generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  isActive  Boolean  @default(true)
  role      UserRole @default(CASHIER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Division {
  id           Int       @id @default(autoincrement())
  divisionName String
  divisionCode String    @unique
  sector       Sector?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  cashiers     Cashier[]
  ddos         DDO[]
  challans     Challan[]
}

model DDO {
  id          Int       @id @default(autoincrement())
  ddoName     String
  ddoEmail    String?
  ddoPhone    String?
  ddoPassword String?
  isActive    Boolean   @default(true)
  divisionId  Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  ddoCode     String    @unique
  cashiers    Cashier[]
  challans    Challan[]
  division    Division  @relation(fields: [divisionId], references: [id])
}

model Cashier {
  id          Int      @id @default(autoincrement())
  name        String
  email       String?
  phone       String?
  password    String?
  isActive    Boolean  @default(true)
  divisionId  Int
  ddoId       Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  cashierCode String   @unique

  ddo      DDO       @relation(fields: [ddoId], references: [id])
  division Division  @relation(fields: [divisionId], references: [id])
  challans Challan[]
}

model ExpenditureType {
  id        Int      @id @default(autoincrement())
  name      String
  sector    Sector?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PlanNonPlan {
  id        Int      @id @default(autoincrement())
  name      String
  sector    Sector?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ObjectHead {
  id        Int      @id @default(autoincrement())
  name      String
  sector    Sector?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Department {
  id        Int      @id @default(autoincrement())
  name      String
  code      String
  sector    Sector?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  challans Challan[]
}

model Challan {
  id                  Int         @id @default(autoincrement())
  cashierId           Int
  counterfoilNo       String?
  counterfoilDate     DateTime?
  challanNo           String?
  challanDate         DateTime?
  challanType         ChallanType
  departmentId        Int
  divisionId          Int
  ddoId               Int
  majorHead           String
  subMajorHead        String
  subSubMajorHead     String
  minorHead           String
  detailHead          String
  treasuryCode        String?
  treasuryChallanNo   String?
  treasuryChallanDate DateTime?
  amount              String
  remarks             String

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cashier    Cashier    @relation(fields: [cashierId], references: [id])
  department Department @relation(fields: [departmentId], references: [id])
  division   Division   @relation(fields: [divisionId], references: [id])
  ddo        DDO        @relation(fields: [ddoId], references: [id])
}

enum UserRole {
  ADMIN
  CASHIER
}

enum Sector {
  COUNCIL
  STATE
}

enum ChallanType {
  STATE
  COUNCIL
  CSS
}
